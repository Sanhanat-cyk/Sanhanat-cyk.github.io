---
import BaseLayout from '../layouts/BaseLayout.astro';
import LandingPage from '../components/pages/LandingPage.astro';
import { commonTh } from '../i18n/locales/th/common';
import { landingTh } from '../i18n/locales/th/landing';

const appUrl = import.meta.env.PUBLIC_APP_URL || '#app';
const schema = [
	{ '@context': 'https://schema.org', '@type': 'SoftwareApplication', name: 'ChillTax', applicationCategory: 'FinanceApplication', operatingSystem: 'LINE, Web', description: landingTh.seo.description, offers: landingTh.pricing.plans.map((plan) => ({ '@type': 'Offer', name: plan.name, price: plan.price.replace(/[^0-9]/g, '') || '0', priceCurrency: 'THB' })) },
	{ '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: landingTh.faq.items.map((item) => ({ '@type': 'Question', name: item.question, acceptedAnswer: { '@type': 'Answer', text: item.answer } })) },
];
---
<BaseLayout locale="th" seo={landingTh.seo} common={commonTh} canonicalPath="/" alternatePath="/en/" schema={schema}>
	<LandingPage content={landingTh} appUrl={appUrl} />
</BaseLayout>
