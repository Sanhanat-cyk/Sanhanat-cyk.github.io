---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LegalPage from '../../components/pages/LegalPage.astro';
import { commonEn } from '../../i18n/locales/en/common';
import { termsEn } from '../../i18n/locales/en/legal';

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://sanhanat-cyk.github.io';
const schema = {
	'@context': 'https://schema.org',
	'@type': 'WebPage',
	name: termsEn.title,
	description: termsEn.seo.description,
	url: `${siteUrl}/en/terms-and-conditions/`,
	inLanguage: 'en-US',
	isPartOf: { '@type': 'WebSite', name: 'ChillTax', url: siteUrl },
	dateModified: termsEn.updated,
};
---
<BaseLayout locale="en" seo={termsEn.seo} common={commonEn} canonicalPath="/en/terms-and-conditions/" alternatePath="/terms-and-conditions/" schema={schema}>
	<LegalPage content={termsEn} />
</BaseLayout>
