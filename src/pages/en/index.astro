---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LandingPage from '../../components/pages/LandingPage.astro';
import { commonEn } from '../../i18n/locales/en/common';
import { landingEn } from '../../i18n/locales/en/landing';

const appUrl = import.meta.env.PUBLIC_APP_URL || '#app';
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://sanhanat-cyk.github.io';

const schema = [
	{
		'@context': 'https://schema.org',
		'@type': 'SoftwareApplication',
		name: 'ChillTax',
		applicationCategory: 'FinanceApplication',
		operatingSystem: 'LINE, Web',
		description: landingEn.seo.description,
		url: `${siteUrl}/en/`,
		offers: landingEn.pricing.plans.map((plan) => ({
			'@type': 'Offer',
			name: plan.name,
			price: plan.price.replace(/[^0-9]/g, '') || '0',
			priceCurrency: 'THB',
		})),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: landingEn.faq.items.map((item) => ({
			'@type': 'Question',
			name: item.question,
			acceptedAnswer: { '@type': 'Answer', text: item.answer },
		})),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'HowTo',
		name: landingEn.steps.title,
		description: landingEn.steps.description,
		step: landingEn.steps.items.map((item, i) => ({
			'@type': 'HowToStep',
			position: i + 1,
			name: item.title,
			text: item.description,
		})),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		name: 'ChillTax',
		url: siteUrl,
		logo: `${siteUrl}/favicon.svg`,
		description: commonEn.footerDescription,
	},
];
---
<BaseLayout locale="en" seo={landingEn.seo} common={commonEn} canonicalPath="/en/" alternatePath="/" schema={schema}>
	<LandingPage content={landingEn} appUrl={appUrl} />
</BaseLayout>
