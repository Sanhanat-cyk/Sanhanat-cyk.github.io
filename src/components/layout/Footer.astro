---
import type { CommonContent, Locale } from '../../i18n/types';
import { localizedPath } from '../../i18n/config';
interface Props { content: CommonContent; locale: Locale; }
const { content, locale } = Astro.props;
---
<footer class="footer">
	<div class="container footer-grid">
		<div><a class="brand" href={localizedPath(locale)}><span aria-hidden="true">🌿</span> {content.brand}</a><p>{content.footerDescription}</p></div>
		<div class="legal-links"><a href={localizedPath(locale, 'privacy-policy')}>{content.privacyLabel}</a><a href={localizedPath(locale, 'terms-and-conditions')}>{content.termsLabel}</a></div>
	</div>
	<div class="container footer-bottom"><p>{content.footerDisclaimer}</p><p>{content.copyright}</p></div>
</footer>
<style>
	.footer { padding: 3.5rem 0 2rem; background: #5b1e05; color: white; }
	.footer-grid { display: grid; gap: 2rem; }
	.brand { display: inline-block; margin-bottom: .5rem; font-size: 1.4rem; font-weight: 900; text-decoration: none; }
	.footer p { color: rgb(255 255 255 / 68%); }
	.legal-links { display: flex; flex-wrap: wrap; align-items: start; gap: 1.25rem; }
	.legal-links a { color: white; font-weight: 700; }
	.footer-bottom { padding-top: 2rem; border-top: 1px solid rgb(255 255 255 / 14%); }
	.footer-bottom p { max-width: 820px; margin-bottom: .5rem; font-size: .88rem; }
	@media (min-width: 700px) { .footer-grid { grid-template-columns: 1fr auto; align-items: start; } }
</style>
