---
import type { LandingContent } from '../../i18n/types';
interface Props { content: LandingContent['finalCta']; appUrl: string; }
const { content, appUrl } = Astro.props;
---
<section id="line" class="section final-cta"><div class="container"><div class="panel"><span class="leaf" aria-hidden="true"></span><h2>{content.title}</h2><p>{content.description}</p><a class="button button-primary" href={appUrl}>{content.cta}</a></div></div></section>
<style>
	.final-cta { background: var(--color-bg); }
	.panel { position: relative; overflow: hidden; padding: clamp(2.5rem, 8vw, 5rem) 1.5rem; border-radius: var(--radius-lg); background: linear-gradient(140deg, #6a2300, #a75f29); color: white; text-align: center; box-shadow: var(--shadow-lg); }
	.panel::before, .panel::after { position: absolute; width: 220px; height: 220px; border-radius: 50%; background: rgb(224 148 61 / 15%); content: ''; }
	.panel::before { top: -120px; left: -90px; } .panel::after { right: -80px; bottom: -140px; }
	.leaf { display: block; width: 50px; height: 50px; margin: 0 auto 1rem; border-radius: 5px 100% 5px 100%; background: linear-gradient(135deg, #e9ae61, #b55a0a); transform: rotate(-8deg); }
	h2 { position: relative; margin-bottom: .7rem; font-size: clamp(2rem, 5vw, 3.8rem); line-height: 1.12; letter-spacing: -.04em; }
	p { position: relative; max-width: 600px; margin: 0 auto 1.5rem; color: rgb(255 255 255 / 70%); }
	.button { position: relative; }
</style>
