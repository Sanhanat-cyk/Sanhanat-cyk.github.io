---
import type { LandingContent } from '../../i18n/types';
interface Props { content: LandingContent['comparison']; appUrl: string; }
const { content, appUrl } = Astro.props;
---
<section class="section comparison"><div class="container"><div class="section-heading"><h2>{content.title}</h2><p>{content.description}</p></div>
	<div class="table-wrap"><table><thead><tr><th scope="col"></th>{content.columns.map((column, i) => <th scope="col" class:list={{ chilltax: i === 0 }}>{column}</th>)}</tr></thead>
	<tbody>{content.rows.map((row) => <tr><th scope="row">{row.feature}</th>{row.values.map((value, i) => <td class:list={{ chilltax: i === 0 }}>{value}</td>)}</tr>)}</tbody></table></div>
	<div class="closing"><p>{content.closing}</p><a class="button button-primary" href={appUrl}>{content.cta}</a></div>
</div></section>
<style>
	.comparison { background: #5b1e05; color: white; }
	.comparison :global(.section-heading p) { color: rgb(255 255 255 / 65%); }
	.table-wrap { overflow-x: auto; border: 1px solid rgb(255 255 255 / 14%); border-radius: 20px; }
	table { width: 100%; min-width: 740px; border-collapse: collapse; background: rgb(255 255 255 / 5%); }
	th, td { padding: 1rem; border-bottom: 1px solid rgb(255 255 255 / 12%); text-align: center; }
	tbody th { width: 30%; text-align: left; }
	.chilltax { background: rgb(224 148 61 / 16%); color: #ffd69d; font-weight: 900; }
	.closing { padding-top: 2rem; text-align: center; }
	.closing p { font-size: 1.1rem; font-weight: 800; }
</style>
