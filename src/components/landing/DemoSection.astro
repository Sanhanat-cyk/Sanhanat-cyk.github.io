---
import type { LandingContent } from '../../i18n/types';
interface Props { content: LandingContent['demo']; lineUrl: string; }
const { content, lineUrl } = Astro.props;
---
<section id="demo" class="section demo">
	<div class="container">
		<div class="section-heading"><h2>{content.title} <span>{content.highlight}</span></h2><p>{content.description}</p></div>
		<div class="video"><div class="play" aria-hidden="true">▶</div><strong>{content.videoLabel}</strong><small>ChillTax</small></div>
		<ol class="steps">{content.steps.map((step) => <li><b>{step.icon}</b><div><h3>{step.title}</h3><p>{step.description}</p></div></li>)}</ol>
		<div class="closing"><p>{content.closing}</p><a class="button button-primary" href={lineUrl}>{content.cta}</a></div>
	</div>
</section>
<style>
	.demo { background: #fff8ef; }
	.section-heading span { color: var(--color-primary); }
	.video { display: grid; min-height: clamp(260px, 50vw, 520px); place-content: center; border: 1px solid #e8d5c2; border-radius: var(--radius-lg); background: radial-gradient(circle at 20% 20%, #f7d8a8, transparent 35%), linear-gradient(135deg, #713016, #401204); color: white; text-align: center; box-shadow: var(--shadow-lg); }
	.video strong, .video small { display: block; }
	.video small { color: rgb(255 255 255 / 60%); }
	.play { display: grid; width: 76px; height: 76px; margin: 0 auto 1rem; padding-left: 4px; border: 1px solid rgb(255 255 255 / 45%); border-radius: 50%; background: rgb(255 255 255 / 18%); font-size: 1.6rem; place-items: center; backdrop-filter: blur(10px); }
	.steps { display: grid; gap: 1rem; padding: 0; margin: 2rem 0 0; list-style: none; }
	.steps li { display: flex; align-items: center; gap: 1rem; padding: 1rem; }
	.steps b { display: grid; width: 42px; height: 42px; flex: none; border-radius: 50%; background: #f0b15e; color: #6a2300; place-items: center; }
	.steps h3 { margin: 0; font-size: 1rem; }
	.steps p { margin: .1rem 0 0; color: var(--color-muted); font-size: .88rem; }
	.closing { padding-top: 2rem; text-align: center; }
	.closing p { font-size: 1.15rem; font-weight: 800; }
	@media (min-width: 700px) { .steps { grid-template-columns: repeat(4, 1fr); } .steps li { display: block; text-align: center; } .steps b { margin: 0 auto .75rem; } }
</style>
