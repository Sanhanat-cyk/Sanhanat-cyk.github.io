---
import type { LandingContent } from '../../i18n/types';
interface Props { content: LandingContent['steps']; lineUrl: string; }
const { content, lineUrl } = Astro.props;
---
<section class="section steps-section"><div class="container"><div class="section-heading"><h2>{content.title}</h2><p>{content.description}</p></div>
	<ol>{content.items.map((item) => <li><b>{item.icon}</b><h3>{item.title}</h3><p>{item.description}</p></li>)}</ol>
	<div class="closing"><p>{content.closing}</p><a class="button button-primary" href={lineUrl}>{content.cta}</a></div>
</div></section>
<style>
	ol { position: relative; display: grid; gap: 1rem; padding: 0; list-style: none; }
	li { padding: 1.5rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); background: var(--color-surface); text-align: center; box-shadow: var(--shadow-sm); }
	li b { display: grid; width: 48px; height: 48px; margin: 0 auto .8rem; border-radius: 50%; background: linear-gradient(135deg, #e9ae61, #c66a1a); color: white; place-items: center; }
	li h3 { margin-bottom: .4rem; font-size: 1.05rem; }
	li p { margin: 0; color: var(--color-muted); font-size: .9rem; }
	.closing { padding-top: 2rem; text-align: center; }
	.closing p { font-weight: 800; }
	@media (min-width: 760px) { ol { grid-template-columns: repeat(4, 1fr); } }
</style>
