---
import type { LandingContent } from '../../i18n/types';
interface Props { content: LandingContent['testimonials']; }
const { content } = Astro.props;
---
<section class="section testimonials"><div class="container"><div class="section-heading"><h2>{content.title}</h2><p>{content.disclaimer}</p></div>
	<div class="grid">{content.items.map((item) => <figure><div class="stars" aria-label="5 stars">★★★★★</div><blockquote>“{item.quote}”</blockquote><figcaption><strong>{item.role}</strong><small>{item.label}</small></figcaption></figure>)}</div>
</div></section>
<style>
	.testimonials { background: #fff8ef; }
	.grid { display: grid; gap: 1rem; }
	figure { padding: 1.5rem; margin: 0; border: 1px solid var(--color-border); border-radius: var(--radius-md); background: white; box-shadow: var(--shadow-sm); }
	.stars { color: #df8b2d; letter-spacing: .08em; }
	blockquote { min-height: 7.5rem; margin: 1rem 0; font-size: 1.02rem; }
	figcaption strong, figcaption small { display: block; }
	figcaption small { color: var(--color-muted); }
	@media (min-width: 760px) { .grid { grid-template-columns: repeat(3, 1fr); } }
</style>
