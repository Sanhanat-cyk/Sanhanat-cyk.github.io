---
import type { CardContent } from '../../i18n/types';
interface Props { id?: string; title: string; description: string; items: CardContent[]; tone?: 'default' | 'warm' | 'dark'; columns?: 3 | 4; }
const { id, title, description, items, tone = 'default', columns = 3 } = Astro.props;
---
<section {id} class:list={['section', 'cards-section', `tone-${tone}`]}>
	<div class="container"><div class="section-heading"><h2>{title}</h2><p>{description}</p></div>
		<div class="grid" style={`--columns:${columns}`}>{items.map((item) => <article><span class="icon" aria-hidden="true">{item.icon}</span><h3>{item.title}</h3><p>{item.description}</p></article>)}</div>
	</div>
</section>
<style>
	.tone-warm { background: #fff8ef; }
	.tone-dark { background: #5b1e05; color: white; }
	.tone-dark :global(.section-heading p), .tone-dark article p { color: rgb(255 255 255 / 65%); }
	.grid { display: grid; gap: 1rem; }
	article { padding: clamp(1.35rem, 3vw, 2rem); border: 1px solid var(--color-border); border-radius: var(--radius-md); background: var(--color-surface); box-shadow: var(--shadow-sm); }
	.tone-dark article { border-color: rgb(255 255 255 / 14%); background: rgb(255 255 255 / 7%); }
	.icon { display: grid; width: 50px; height: 50px; margin-bottom: 1rem; border-radius: 14px; background: #fff0d8; font-size: 1.5rem; place-items: center; }
	h3 { margin-bottom: .5rem; font-size: 1.14rem; }
	article p { margin: 0; color: var(--color-muted); }
	@media (min-width: 680px) { .grid { grid-template-columns: repeat(2, 1fr); } }
	@media (min-width: 980px) { .grid { grid-template-columns: repeat(var(--columns), 1fr); } }
</style>
