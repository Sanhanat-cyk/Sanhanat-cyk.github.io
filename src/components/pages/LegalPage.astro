---
import type { LegalPageContent } from '../../i18n/types';
interface Props { content: LegalPageContent; }
const { content } = Astro.props;
---
<article class="legal section"><div class="container"><header><h1>{content.title}</h1><p class="updated">{content.updated}</p><p class="intro">{content.intro}</p></header>
	<div class="content">{content.sections.map((section) => <section><h2>{section.heading}</h2>{section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}{section.items && <ul>{section.items.map((item) => <li>{item}</li>)}</ul>}</section>)}</div>
</div></article>
<style>
	.legal .container { max-width: 850px; }
	header { padding-bottom: 2rem; border-bottom: 1px solid var(--color-border); }
	h1 { margin-bottom: .5rem; font-size: clamp(2.5rem, 7vw, 4.8rem); line-height: 1.08; letter-spacing: -.045em; }
	.updated { color: var(--color-muted); font-size: .9rem; }
	.intro { max-width: 720px; margin: 1.5rem 0 0; font-size: 1.08rem; }
	.content { display: grid; gap: 2.5rem; padding-top: 2.5rem; }
	section h2 { margin-bottom: .7rem; font-size: clamp(1.35rem, 3vw, 1.8rem); }
	section p, li { color: var(--color-muted); }
	section p:last-child { margin-bottom: 0; }
	li + li { margin-top: .45rem; }
</style>
