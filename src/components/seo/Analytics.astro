---
interface Props {
	debugMode?: boolean;
}

const { debugMode = false } = Astro.props;
const measurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
---
{measurementId && (
	<>
		<meta name="chilltax-ga4-id" content={measurementId} />
		<meta name="chilltax-ga4-debug" content={String(debugMode)} />
	</>
)}
<script>
	import '../../scripts/analytics';
</script>
